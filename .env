# =========================================================================
# DevFint Environment Variables Configuration
# =========================================================================

# 1. Gemini AI API Key
# -------------------------------------------------------------------------
# AI Studio automatically injects this at runtime from user secrets.
# For local dev or production deployment, configure this with your Gemini API key.
GEMINI_API_KEY=""

# 2. Host Application URL
# -------------------------------------------------------------------------
# Set this to your application's domain/hosted URL (e.g. https://your-app.com).
# Used for relative navigation and self-referential links.
APP_URL="http://localhost:3000"

# 3. SMTP Email Verification Service Configuration
# -------------------------------------------------------------------------
# Enter your mail provider's SMTP details here to enable real-time email dispatch
# for user logins and registration verification.
#
# Common SMTP Port Guide:
# - Port 587: Secure STARTTLS (Set SMTP_SECURE="false") - RECOMMENDED
# - Port 465: Explicit SSL/TLS (Set SMTP_SECURE="true")
# - Port 25/2525: Non-secure (Set SMTP_SECURE="false")

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE="true"
SMTP_USER="babatundemoyo05@gmail.com"

# SECURITY WARNING: Never use your actual email login password here!
# For Gmail, generate a 16-character App Password via your Google Account:
# Settings -> Security -> 2-Step Verification -> App Passwords
SMTP_PASS="xeyeyurnodftmyga"

SMTP_FROM='"DevFint Security" <babatundemoyo05@gmail.com>'
